# Frontend/public
VITE_APP_TITLE="Playlist Generate"

# App/server
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/playlist_generate?sslmode=disable"
SERVER_URL="http://127.0.0.1:3000"
BETTER_AUTH_URL="http://127.0.0.1:3000"
BETTER_AUTH_SECRET="replace-with-a-random-secret"

# Providers/server
